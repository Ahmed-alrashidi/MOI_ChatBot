# =========================================================================
# File Name: .gitignore
# Project: Absher Smart Assistant (MOI ChatBot)
# Edition: v3.0 (SVG Assets + Auth DB Protection)
# Purpose: Version Control Exclusion for Security, Privacy & Performance
# =========================================================================

# --- 1. Security & Secrets (Zero Trust Policy) 🔒 ---
.env
.env*
.secrets
*.pem
*.key
hf_token
auth_token.txt
users/users_db.json

# --- 2. Large Models & Cache (HPC/A100 Resources) 🏋️‍♂️ ---
models/
models_cache/
hub/
snapshots/
xet/
*.safetensors
*.bin
*.pt
*.pth
*.gguf
*.h5
*.ckpt
*.onnx

# --- 3. Vector Database & Indices 🔍 ---
data/faiss_index/
*.faiss
*.pkl

# --- 4. Python & Environment Artifacts 🐍 ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.anaconda/
.conda/
pip-log.txt
*.egg-info/
.coverage
.ipynb_checkpoints/

# --- 5. Data Layer & Knowledge Management 📂 ---
data/temp/
*.tmp

# PRESERVE: Keep master structures and the verified Knowledge Graph
!data/Data_Master/
!data/Data_Chunk/
!data/data_processed/services_knowledge_graph.json
!data/Data_Master/MOI_Master_Knowledge.csv

# --- 6. Privacy & Telemetry (GRC Requirement) 🙈 ---
outputs/user_analytics/
logs/*.log
flagged/
.gradio/

# --- 7. Outputs & Media Assets 📝 ---
outputs/audio/*
outputs/audio_cache/*
outputs/images/*
!outputs/audio/.gitkeep
!ui/assets/*.png
!ui/assets/*.jpg
!ui/assets/*.svg

# --- 8. Benchmarks & Ground Truth 📊 ---
temp_results.csv
retrieval_report_*.csv
# ALLOW: Ensure all files in Benchmarks/results are tracked and uploaded
!Benchmarks/results/
!Benchmarks/results/*
!Benchmarks/data/ground_truth_polyglot_V2.csv

# --- 9. OS & IDE Configuration 💻 ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~